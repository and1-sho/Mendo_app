#!/bin/bash
# ===================================================
# 開発用コンテナの起動前処理スクリプト
# Rails サーバーを起動する直前に自動で実行される
# ===================================================

set -e  # エラーが起きたら即座に終了する（安全のため）

# Rails サーバーを起動しようとしている場合だけ前処理を行う
if [ "${1}" = "./bin/rails" ] && [ "${2}" = "server" ]; then
  # 足りない gem があればインストールする（Gemfile を変更した後も安心）
  bundle check || bundle install

  # データベースの準備（存在しなければ作成・マイグレーションを実行）
  ./bin/rails db:prepare
fi

# 引数として渡されたコマンドを実行する（CMD で指定した rails server など）
exec "$@"
