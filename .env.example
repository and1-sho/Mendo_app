# ===================================================
# 環境変数のテンプレート（Git に含めてOK）
# クローン後にこのファイルをコピーして .env を作成してください
#   cp .env.example .env
# ===================================================

# --- 開発環境 ---
APP_HOST=localhost

# オーナー（発注依頼メールの宛先）
OWNER_EMAIL=owner@example.com

# 送信元メールアドレス（省略時は noreply@mendo-app.local）
# MAILER_FROM=noreply@mendo-app.local

# --- 本番環境（Render）で設定する変数 ---
# DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
# RAILS_MASTER_KEY=（config/master.key の中身）
# APP_HOST=your-app.onrender.com
# OWNER_EMAIL=owner@example.com
#
# 本番メール（未設定でもアプリは動く。在庫アラートは送られない）
# SMTP_ADDRESS=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# MAILER_FROM=noreply@your-domain.com
#
# Supabase Storage（画像保存）
# SUPABASE_S3_ENDPOINT=https://xxxx.storage.supabase.co/storage/v1/s3
# SUPABASE_S3_REGION=ap-northeast-1
# SUPABASE_S3_BUCKET=item-images
# SUPABASE_S3_ACCESS_KEY_ID=
# SUPABASE_S3_SECRET_ACCESS_KEY=
