# ===================================================
# 環境変数のテンプレートファイル（Git に含めてOK）
# このファイルをコピーして .env を作り、実際の値を入力してください
#   cp .env.example .env
# ===================================================

# Railsのシークレットキー
# 生成方法: docker compose run --rm web bin/rails secret
SECRET_KEY_BASE=

# アプリのホスト名
APP_HOST=localhost
