# ===================================================
# 環境変数のテンプレート（Git に含めてOK）
# クローン後にこのファイルをコピーして .env を作成してください
#   cp .env.example .env
# ===================================================

# --- 開発環境 ---
APP_HOST=localhost

# オーナー（発注依頼メールの宛先）
OWNER_EMAIL=owner@example.com

# 送信元メールアドレス（省略時は noreply@mendo-app.local）
# MAILER_FROM=noreply@mendo-app.local

# --- 本番環境（Render）で設定する変数 ---
# DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
# RAILS_MASTER_KEY=（config/master.key の中身）
# APP_HOST=your-app.onrender.com
# OWNER_EMAIL=owner@example.com
