<!DOCTYPE html>
<html>
  <head>
    <title>MendoApp</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>
    <%# フラッシュメッセージ（数秒後に自動で消える） %>
    <% if flash[:notice] %>
      <p id="flash-notice"><%= flash[:notice] %></p>
    <% end %>
    <% if flash[:alert] %>
      <p id="flash-alert"><%= flash[:alert] %></p>
    <% end %>

    <%= yield %>

    <script>
      // フラッシュメッセージを3秒後に非表示にする
      setTimeout(function() {
        var notice = document.getElementById('flash-notice');
        var alert  = document.getElementById('flash-alert');
        if (notice) notice.style.display = 'none';
        if (alert)  alert.style.display  = 'none';
      }, 3000);
    </script>
  </body>
</html>
