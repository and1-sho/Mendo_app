<%# 登録・編集で共通して使うフォームのパーツ %>

<%# 新規登録なら admin_items_path へ POST、編集なら admin_item_path へ PATCH %>
<%= form_with model: item, url: item.new_record? ? admin_items_path : admin_item_path(item) do |f| %>

  <%# バリデーションエラーがある場合に表示 %>
  <% if item.errors.any? %>
    <ul>
      <% item.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  <% end %>

  <div class="auth-form__field form-num">
    <%= f.label :item_code, "商品番号", class: "auth-form__label" %>
    <%= f.number_field :item_code, class: "auth-form__input" %>
  </div>

  <div class="auth-form__field">
    <%= f.label :name, "備品名", class: "auth-form__label" %>
    <%= f.text_field :name, class: "auth-form__input" %>
  </div>

  <div class="form-num__box">
    <div class="auth-form__field form-num">
      <%= f.label :stock, "在庫数", class: "auth-form__label" %>
      <%= f.number_field :stock, class: "auth-form__input" %>
    </div>

    <div class="auth-form__field form-num">
      <%= f.label :order_trigger, "注文トリガー数", class: "auth-form__label" %>
      <%= f.number_field :order_trigger, class: "auth-form__input" %>
    </div>

    <div class="auth-form__field form-num">
      <%= f.label :reorder_quantity, "目標補充数", class: "auth-form__label" %>
      <%= f.number_field :reorder_quantity, class: "auth-form__input" %>
    </div>
  </div>

  <div class="auth-form__field form__field-image">
    <%= f.label :image, "画像", class: "auth-form__label" %>

    <%= f.file_field :image,
        id: "item-image",
        accept: "image/*",
        class: "image-input",
        onchange: "previewImage(event)" %>

    <div class="item-image__box">
      <label for="item-image" class="image-upload">
        <div class="image-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="request-new__video-drop-svg" width="33" height="33">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" />
          </svg>
        </div>
        <p class="image-text">タップで画像を追加する</p>
        <span class="image-label">＋ 画像を選択</span>
      </label>

      <div class="image-preview">
        <%# 保存済みの備品だけ image_tag を使う（未保存だと signed_id エラーになる） %>
        <% if item.persisted? && item.image.attached? %>
          <%= image_tag item.image, id: "preview", class: "preview-image" %>
        <% else %>
          <img id="preview" class="preview-image" style="display: none;">
        <% end %>
      </div>
    </div>
  </div>

  <%= f.submit "登録する", class: "submit-btn items-form-btn" %>

<% end %>

<script>
  function previewImage(event) {
    const file = event.target.files[0];
    if (!file) return;

    const preview = document.getElementById("preview");

    preview.src = URL.createObjectURL(file);
    preview.style.display = "block";
  }
</script>
